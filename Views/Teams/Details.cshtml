@model appointly.Models.Team

@{
    ViewData["Title"] = "Team Details";
    var canManageTeam = ViewBag.CanManageTeam is bool value && value;
}

<div class="container py-4 form-container">
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h2 class="mb-3 fw-semibold">Team Details</h2>
            <dl class="row mb-4">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
            </dl>

            <h4 class="fw-semibold mb-3">Members</h4>
            <ul class="list-group mb-3">
                @foreach (var member in Model.Members)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@member.User?.DisplayName (@member.User?.Email) - @member.Role</span>
                        @if (canManageTeam)
                        {
                            <form asp-controller="TeamMembers" asp-action="Remove" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="teamId" value="@Model.Id" />
                                <input type="hidden" name="userId" value="@member.UserId" />
                                <button type="submit" class="btn btn-sm btn-danger rounded-4">Remove</button>
                            </form>
                        }
                    </li>
                }
            </ul>

            @if (canManageTeam)
            {
                <div class="mb-4">
                    <h5 class="fw-semibold">Add Member</h5>
                    <form asp-controller="TeamMembers" asp-action="Add" method="post" class="row g-2 align-items-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="teamId" value="@Model.Id" />
                        <div class="col-auto">
                            <select name="userId" class="form-select rounded-4" style="min-width:200px;"
                                    asp-items="@(new SelectList(ViewBag.PotentialMembers, "Id", "DisplayName"))">
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-success rounded-4 px-3">Add</button>
                        </div>
                    </form>
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <a asp-action="Index" class="btn btn-dark-custom rounded-4 px-4 fw-semibold">Back to List</a>
                @if (canManageTeam)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-custom rounded-4 px-4 fw-semibold">Edit</a>
                }
            </div>
        </div>
    </div>
</div>
