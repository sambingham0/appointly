@model appointly.Models.Team

@{
    ViewData["Title"] = "Delete Team";
}

<div class="container py-4 form-container">
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h2 class="mb-3 fw-semibold text-danger">Delete Team</h2>
            <p class="mb-4">Are you sure you want to delete this team?</p>
            <dl class="row mb-4">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>
            </dl>
            <form asp-action="Delete" class="d-flex gap-2 align-items-center">
                <input type="hidden" asp-for="Id" />
                <input type="submit" value="Delete" class="btn btn-danger rounded-4 px-4 fw-semibold" />
                <a asp-action="Index" class="btn btn-dark-custom rounded-4 px-4 fw-semibold">Cancel</a>
            </form>
        </div>
    </div>
</div>
