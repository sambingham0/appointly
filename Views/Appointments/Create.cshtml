@model appointly.Models.Appointment

<div class="container py-4" style="max-width: 600px;">

@* added opening form tag to fix build errors *@
<form asp-action="Create" method="post">
    <div>
        <label>Title</label>
        <input asp-for="Title" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div>
        <label>Description</label>
        <input asp-for="Description" maxlength="500" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div>
        <label>Start (UTC)</label>
        <input asp-for="StartTimeUtc" type="datetime-local" />
        <span asp-validation-for="StartTimeUtc" class="text-danger"></span>
    </div>

    <div>
        <label>End (UTC)</label>
        <input asp-for="EndTimeUtc" type="datetime-local" />
        <span asp-validation-for="EndTimeUtc" class="text-danger"></span>
    </div>

        <div class="form-floating">
            <textarea asp-for="Description" class="form-control rounded-4" placeholder="Description" style="height: 100px;"></textarea>
            <label asp-for="Description">Description</label>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-6 form-floating">
                <input asp-for="StartTimeUtc" type="datetime-local" class="form-control rounded-4" placeholder="Start" />
                <label asp-for="StartTimeUtc">Start</label>
                <span asp-validation-for="StartTimeUtc" class="text-danger small"></span>
            </div>
            <div class="col-12 col-md-6 form-floating">
                <input asp-for="EndTimeUtc" type="datetime-local" class="form-control rounded-4" placeholder="End" />
                <label asp-for="EndTimeUtc">End</label>
                <span asp-validation-for="EndTimeUtc" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-floating">
            <select asp-for="Status"
                    asp-items="Html.GetEnumSelectList<appointly.Models.AppointmentStatus>()"
                    class="form-select rounded-4">
            </select>
            <label asp-for="Status">Status</label>
        </div>

        <div class="form-floating">
            <select asp-for="TeamId" asp-items="ViewBag.Teams" class="form-select rounded-4">
                <option value="">-- None --</option>
            </select>
            <label asp-for="TeamId">Team (optional)</label>
        </div>

        <div class="d-flex gap-2 mt-2">
            <button type="submit"
                    class="btn text-white rounded-4 px-4 fw-semibold"
                    style="background-color: #7B6FA0; color:#2B2B2B";">
                Save Appointment
            </button>
            <a asp-action="AppointmentsByUser"
               class="btn rounded-4 px-4 fw-semibold"
               style="background-color: #2B2B2B; color: #F5F2EE;">
                Cancel
            </a>
        </div>

    <button type="submit">Save</button>
    <a asp-action="Index">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
