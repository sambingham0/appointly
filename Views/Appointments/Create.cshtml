@model appointly.Models.Appointment
<div asp-validation-summary="All"></div>
<h1>Create Appointment</h1>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <div>
        <label>Title</label>
        <input asp-for="Title" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div>
        <label>Description</label>
        <input asp-for="Description" maxlength="500" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div>
        <label>Start (UTC)</label>
        <input asp-for="StartTimeUtc" type="datetime-local" />
        <span asp-validation-for="StartTimeUtc" class="text-danger"></span>
    </div>

    <div>
        <label>End (UTC)</label>
        <input asp-for="EndTimeUtc" type="datetime-local" />
        <span asp-validation-for="EndTimeUtc" class="text-danger"></span>
    </div>

    <div>
        <label>Status</label>
        <select asp-for="Status"
                asp-items="Html.GetEnumSelectList<appointly.Models.AppointmentStatus>()">
        </select>
    </div>

    <div>
        <label>Team (optional)</label>
        <select asp-for="TeamId" asp-items="ViewBag.Teams">
            <option value="">-- None --</option>
        </select>
    </div>

    <button type="submit">Save</button>
    <a asp-action="Index">Cancel</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}