@model IEnumerable<appointly.Models.Appointment>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>My Appointments</h2>
        <a href="@Url.Action("Create", "Appointments")" class="btn btn-dark">+ New Appointment</a>
    </div>

    @if (!Model.Any())
    {
        <p class="text-muted">No appointments yet.</p>
    }
    else
    {
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Status</th>
                    <th>Team</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>@a.Title</td>
                        <td>@a.StartTimeUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                        <td>@a.EndTimeUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                        <td>
                            <span class="badge @(a.Status == appointly.Models.AppointmentStatus.Scheduled ? "bg-primary" : a.Status == appointly.Models.AppointmentStatus.Completed ? "bg-success" : "bg-secondary")">
                                @a.Status
                            </span>
                        </td>
                        <td>@(a.Team?.Name ?? "-")</td>
                        <td>
                            <a href="@Url.Action("Details", "Appointments", new { id = a.Id })" class="btn btn-sm btn-outline-dark">View</a>
                            <a href="@Url.Action("Edit", "Appointments", new { id = a.Id })" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a href="@Url.Action("Delete", "Appointments", new { id = a.Id })" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>