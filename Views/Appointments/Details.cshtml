@model appointly.Models.Appointment

@{
    var canManageAppointment = ViewBag.CanManageAppointment is bool value && value;
}

<h1>Appointment Details</h1>

<div class="container py-4 form-container">
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h2 class="mb-3 fw-semibold">Appointment Details</h2>
            <dl class="row mb-4">
                <dt class="col-sm-3">Title</dt>
                <dd class="col-sm-9">@Model.Title</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Model.Description</dd>

                <dt class="col-sm-3">Start</dt>
                <dd class="col-sm-9">@Model.StartTimeUtc</dd>

                <dt class="col-sm-3">End</dt>
                <dd class="col-sm-9">@Model.EndTimeUtc</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Created By</dt>
                <dd class="col-sm-9">@Model.CreatedByUser?.DisplayName</dd>

                <dt class="col-sm-3">Team</dt>
                <dd class="col-sm-9">@Model.Team?.Name</dd>
            </dl>

            <h4 class="fw-semibold mb-3">Participants</h4>
            <ul class="list-group mb-3">
                @foreach (var p in Model.Participants)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@p.User?.DisplayName</span>
                        @if (canManageAppointment)
                        {
                            <form asp-controller="AppointmentParticipants"
                                  asp-action="Remove"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="appointmentId" value="@Model.Id" />
                                <input type="hidden" name="userId" value="@p.UserId" />
                                <button type="submit" class="btn btn-sm btn-danger rounded-4">Remove</button>
                            </form>
                        }
                    </li>
                }
            </ul>

            @if (canManageAppointment)
            {
                <div class="mb-4">
                    <h5 class="fw-semibold">Add Participant</h5>
                    <form asp-controller="AppointmentParticipants"
                          asp-action="Add"
                          method="post"
                          class="row g-2 align-items-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="appointmentId" value="@Model.Id" />
                        <div class="col-auto">
                            <select name="userId" asp-items="ViewBag.PotentialParticipants" class="form-select rounded-4">
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-success rounded-4 px-3">Add</button>
                        </div>
                    </form>
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <a asp-action="AppointmentsByUser" class="btn btn-dark-custom rounded-4 px-4 fw-semibold">Back</a>
                @if (canManageAppointment)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-custom rounded-4 px-4 fw-semibold">Edit</a>
                }
            </div>
        </div>
    </div>
</div>