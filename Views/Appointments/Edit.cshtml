@model appointly.Models.Appointment

<div class="container py-4 form-container">
    
    <h2 class="mb-3 fw-semibold">Edit Appointment</h2>
    
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        
        <div class="form-floating mb-3">
            <input asp-for="Title" class="form-control rounded-4" placeholder="Title" />
            <label asp-for="Title">Title</label>
            <span asp-validation-for="Title" class="text-danger small"></span>
        </div>
        
        <div class="form-floating mb-3">
            <textarea asp-for="Description"
                      class="form-control rounded-4 form-textarea"
                      placeholder=" "></textarea>
            <label asp-for="Description">Description</label>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>
        
        <div class="row g-3 mb-3">
            <div class="col-12 col-md-6 form-floating">
                <input asp-for="StartTimeUtc"
                       type="datetime-local"
                       class="form-control rounded-4"
                       placeholder="Start" />
                <label asp-for="StartTimeUtc">Start</label>
                <span asp-validation-for="StartTimeUtc" class="text-danger small"></span>
            </div>
            <div class="col-12 col-md-6 form-floating">
                <input asp-for="EndTimeUtc"
                       type="datetime-local"
                       class="form-control rounded-4"
                       placeholder="End" />
                <label asp-for="EndTimeUtc">End</label>
                <span asp-validation-for="EndTimeUtc" class="text-danger small"></span>
            </div>
        </div>
        
        <div class="form-floating mb-3">
            <select asp-for="Status"
                    asp-items="Html.GetEnumSelectList<appointly.Models.AppointmentStatus>()"
                    class="form-select rounded-4">
            </select>
            <label asp-for="Status">Status</label>
            <span asp-validation-for="Status" class="text-danger small"></span>
        </div>
        
        <div class="form-floating mb-3">
            <select asp-for="TeamId"
                    asp-items="ViewBag.Teams"
                    class="form-select rounded-4">
                <option value="">-- None --</option>
            </select>
            <label asp-for="TeamId">Team (optional)</label>
            <span asp-validation-for="TeamId" class="text-danger small"></span>
        </div>
        
        <div class="d-flex gap-2 mt-3">
            <button type="submit"
                    class="btn btn-primary-custom rounded-4 px-4 fw-semibold">
                Save Changes
            </button>

            <a asp-action="Index"
               class="btn btn-dark-custom rounded-4 px-4 fw-semibold">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}