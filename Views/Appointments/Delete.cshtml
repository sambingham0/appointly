@model appointly.Models.Appointment

<div class="container py-4 form-container">
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h2 class="mb-3 fw-semibold text-danger">Delete Appointment</h2>
            <p class="mb-4">Are you sure you want to delete this appointment?</p>
            <div class="mb-4">
                <span class="fw-semibold fs-5">@Model.Title</span>
            </div>
            <form asp-action="Delete" method="post" class="d-flex gap-2 align-items-center">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger rounded-4 px-4 fw-semibold">Delete</button>
                <a asp-action="AppointmentsByUser" class="btn btn-dark-custom rounded-4 px-4 fw-semibold">Cancel</a>
            </form>
        </div>
    </div>
</div>