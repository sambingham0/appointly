@model appointly.Models.User

@{
    ViewData["Title"] = "Delete User";
}

<div class="container py-4 form-container">
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h2 class="mb-3 fw-semibold text-danger">Delete User</h2>
            <p class="mb-4">Are you sure you want to delete this user?</p>
            <dl class="row mb-4">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.Id</dd>
                <dt class="col-sm-3">Display Name</dt>
                <dd class="col-sm-9">@Model.DisplayName</dd>
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>
            </dl>
            <form asp-action="Delete" method="post" class="d-flex gap-2 align-items-center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="btn btn-danger rounded-4 px-4 fw-semibold">Delete</button>
                <a asp-action="Index" class="btn btn-dark-custom rounded-4 px-4 fw-semibold">Cancel</a>
            </form>
        </div>
    </div>
</div>