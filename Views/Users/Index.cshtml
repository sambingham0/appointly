@model IEnumerable<appointly.Models.User>

@{
    ViewData["Title"] = "Users";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-semibold mb-0">Users</h2>
        <a asp-action="Create" class="btn btn-primary-custom rounded-4 px-4 fw-semibold">Create New</a>
    </div>
    <div class="card shadow-sm rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Id</th>
                        <th>Display Name</th>
                        <th>Email</th>
                        <th style="width: 180px;"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.Id</td>
                        <td>@u.DisplayName</td>
                        <td>@u.Email</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary rounded-4 me-1">Details</a>
                            <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary rounded-4 me-1">Edit</a>
                            <a asp-action="Delete" asp-route-id="@u.Id" class="btn btn-sm btn-outline-danger rounded-4">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>