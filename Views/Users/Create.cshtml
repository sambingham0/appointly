@model appointly.Models.User

@{
    ViewData["Title"] = "Create User";
}

<div class="container py-4 form-container">
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h2 class="mb-3 fw-semibold">Create User</h2>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="form-floating mb-3">
                    <input asp-for="Id" class="form-control rounded-4" placeholder=" " />
                    <label asp-for="Id">Id</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="DisplayName" class="form-control rounded-4" placeholder=" " />
                    <label asp-for="DisplayName">Display Name</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control rounded-4" placeholder=" " />
                    <label asp-for="Email">Email</label>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary-custom rounded-4 px-4 fw-semibold">Save</button>
                    <a asp-action="Index" class="btn btn-dark-custom rounded-4 px-4 fw-semibold">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>