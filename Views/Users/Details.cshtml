@model appointly.Models.User

@{
    ViewData["Title"] = "User Details";
}

<div class="container py-4 form-container">
    <div class="card shadow-sm rounded-4">
        <div class="card-body">
            <h2 class="mb-3 fw-semibold">User Details</h2>
            <dl class="row mb-4">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@Model.Id</dd>
                <dt class="col-sm-3">Display Name</dt>
                <dd class="col-sm-9">@Model.DisplayName</dd>
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>
            </dl>

            <h4 class="fw-semibold mb-3">Teams</h4>
            @if (Model.TeamMemberships.Any())
            {
                <ul class="list-group mb-3">
                    @foreach (var tm in Model.TeamMemberships)
                    {
                        <li class="list-group-item">
                            <a asp-controller="Teams" asp-action="Details" asp-route-id="@tm.TeamId">@tm.Team?.Name</a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No teams.</p>
            }

            <h4 class="fw-semibold mb-3">Participating Appointments</h4>
            @if (Model.AppointmentParticipations.Any())
            {
                <ul class="list-group mb-3">
                    @foreach (var ap in Model.AppointmentParticipations)
                    {
                        <li class="list-group-item">
                            <a asp-controller="Appointments" asp-action="Details" asp-route-id="@ap.AppointmentId">
                                @ap.Appointment?.Title
                            </a>
                            <span class="text-muted">(@ap.Appointment?.StartTimeUtc.ToString("g"))</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No appointments.</p>
            }

            <div class="d-flex gap-2 mt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-custom rounded-4 px-4 fw-semibold">Edit</a>
                <a asp-action="Index" class="btn btn-dark-custom rounded-4 px-4 fw-semibold">Back</a>
            </div>
        </div>
    </div>
</div>